{
  "name": "blackfish-backend",
  "version": "1.0.0",
  "type": "module",
  "private": true,
  "scripts": {
    "build": "node -e \"const v=process.version.match(/v(\\d+)/)[1];if(parseInt(v)<18){console.error('❌ Node.js 18+ required. Current version:',process.version);process.exit(1)}\" && tsc && node scripts/build.mjs",
    "dev": "tsx watch server.ts",
    "start": "tsx server.ts",
    "start:prod": "NODE_ENV=production tsx server.ts",
    "pm2:start": "pm2 start ecosystem.config.cjs",
    "pm2:start:prod": "pm2 start ecosystem.config.cjs --env production",
    "pm2:stop": "pm2 stop blackfish-backend",
    "pm2:restart": "pm2 restart blackfish-backend",
    "pm2:delete": "pm2 delete blackfish-backend",
    "pm2:logs": "pm2 logs blackfish-backend",
    "pm2:status": "pm2 status",
    "redeploy": "rm -rf dist && tsc && node scripts/build.mjs && rm -rf node_modules && scp -r ./* root@193.233.198.34:/opt/blackfish-backend/ && bun install",
    "deploy": "tsc && tsx server.ts"
  },
  "dependencies": {
    "@fastify/cors": "^9.0.1",
    "ethers": "^6.15.0",
    "fastify": "^4.26.0",
    "got": "^14.6.3",
    "got-scraping": "^4.1.2",
    "javascript-obfuscator": "^4.1.1"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "pino-pretty": "^13.1.2",
    "pm2": "^5.3.0",
    "tsx": "^4.7.0",
    "typescript": "^5.0.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}